### Get or create myself - mod register/login flow ("Creator" Auth Scheme)

GET {{url}}/api/v1/creators/me
Authorization: Creator name={{creatorName}}&id={{creatorId}}&provider=paradox&hwid={{hwid}}
Accept-Language: {{locale}}
X-Timezone-Offset: {{utcOffset}}
X-Forwarded-For: {{ip}}

> {%
  client.global.set("creator", response.body);
%}

### Get myself - web/api login-only flow ("CreatorID" Auth Scheme)

GET {{url}}/api/v1/creators/me
Authorization: CreatorID {{creatorId}}
Accept-Language: {{locale}}
X-Timezone-Offset: {{utcOffset}}
X-Forwarded-For: {{ip}}

> {%
  client.global.set("creator", response.body);
%}

### Get by creator name

GET {{url}}/api/v1/creators/toverux
Authorization: CreatorID {{creatorId}}
Accept-Language: {{locale}}
X-Timezone-Offset: {{utcOffset}}
X-Forwarded-For: {{ip}}

> {%
  client.global.set("creator", response.body);
%}

### Update myself

PUT {{url}}/api/v1/creators/me
Authorization: CreatorID {{creatorId}}
Accept-Language: {{locale}}
Content-Type: application/json
X-Timezone-Offset: {{utcOffset}}
X-Forwarded-For: {{ip}}

{
  "locale": "en-US",
  "metadata": {
    "modVersion": "2026.0.0",
    "enableMainMenuSlideshow": true,
    "enableLoadingScreenBackground": true,
    "showFeaturedAsset": true,
    "showCreatorSocials": true,
    "showViewCount": true,
    "namesTranslationMode": "translate",
    "popularScreenshotWeight": 10,
    "trendingScreenshotWeight": 10,
    "recentScreenshotWeight": 10,
    "archeologistScreenshotWeight": 10,
    "randomScreenshotWeight": 10,
    "supporterScreenshotWeight": 10,
    "viewMaxAge": 60,
    "screenshotResolution": "4k",
    "createLocalScreenshot": true,
    "disableGlobalIllumination": true,
    "paradoxModsBrowsingPreference": "in-game"
  }
}

> {%
  client.global.set("creator", response.body);
%}

### Get statistics for a creator

GET {{url}}/api/v1/creators/{{creator.id}}/stats
Authorization: CreatorID {{creatorId}}
Accept-Language: {{locale}}
X-Timezone-Offset: {{utcOffset}}
X-Forwarded-For: {{ip}}
